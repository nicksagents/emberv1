{
  "name": "@ember/project-scaffold-mcp",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "project-scaffold-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "bash -lc 'shopt -s globstar nullglob; tests=(src/**/*.test.ts); if [ ${#tests[@]} -eq 0 ]; then echo \"No test files found.\"; exit 0; fi; node --import tsx --test \"${tests[@]}\"'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
