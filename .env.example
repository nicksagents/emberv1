## Network binding
# Set to 0.0.0.0 to allow connections from Tailscale, LAN, or other network interfaces.
# Default 127.0.0.1 only accepts local connections.
EMBER_WEB_HOST=0.0.0.0
EMBER_WEB_PORT=3000
EMBER_RUNTIME_HOST=0.0.0.0
EMBER_RUNTIME_PORT=3005
# NEXT_PUBLIC_API_URL must point to an address reachable from the browser.
# For Tailscale/LAN access, use the machine's IP (e.g., http://100.x.x.x:3005).
# For local-only use, http://127.0.0.1:3005 works.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3005

# API auth (recommended outside local development).
# Use EMBER_API_TOKEN for all scopes or set scoped tokens.
# EMBER_API_TOKEN=
# EMBER_API_TOKEN_READ=
# EMBER_API_TOKEN_WRITE=
# EMBER_API_TOKEN_ADMIN=

# Comma-separated allowlist for browser origins allowed to call the runtime API.
# In dev mode, all local network IPs are auto-detected and allowed.
# For production, list allowed origins explicitly.
# EMBER_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optional hardening toggles.
# EMBER_ENABLE_HSTS=1
# EMBER_ENABLE_RUNTIME_MCP_INSTALL=1
# EMBER_MCP_REMOTE_ALLOWLIST=*.example.com,localhost
# EMBER_PROVIDER_SECRETS_BACKEND=auto
# EMBER_ENABLE_IDEMPOTENCY_KEYS=1
# EMBER_IDEMPOTENCY_TTL_MS=600000
# EMBER_IDEMPOTENCY_MAX_ENTRIES=1000
# EMBER_ENABLE_CHECKPOINTS=1
# EMBER_CHECKPOINT_RETENTION_COUNT=50
# EMBER_ENABLE_PARALLEL_TASKS=1
# EMBER_PARALLEL_MAX_TASKS=4
# EMBER_PARALLEL_MAX_DEPTH=1
# EMBER_PARALLEL_MAX_CONCURRENCY=4
# EMBER_PARALLEL_CHILD_TIMEOUT_MS=60000
# EMBER_ENABLE_FAILOVER=1
# EMBER_FAILOVER_FAILURE_THRESHOLD=2
# EMBER_FAILOVER_MAX_SWITCHES_PER_TURN=3

# Production operations + request handling
# EMBER_DISPATCH_TIMEOUT_MS=10000
# EMBER_MAX_AGENT_LOOP=16
# EMBER_MAX_ROLE_VISITS=5
# EMBER_SHUTDOWN_DRAIN_MS=30000

# Audit log rotation
# EMBER_AUDIT_LOG_MAX_SIZE_BYTES=52428800
# EMBER_AUDIT_LOG_MAX_ROTATED=5

# Circuit breaker tuning
# EMBER_CB_THRESHOLD=3
# EMBER_CB_RESET_MS=60000
# EMBER_FAILOVER_EVENT_HISTORY=240

# Terminal execution tuning
# EMBER_TERMINAL_TIMEOUT=120000
# EMBER_TERMINAL_MAX_TIMEOUT=600000
# EMBER_TERMINAL_MAX_OUTPUT=4000000
# EMBER_TERMINAL_SESSION_IDLE_TTL_MS=900000
# EMBER_TERMINAL_APPROVAL_TTL_MS=1800000
# EMBER_SUDO_TTL_MS=300000
# EMBER_SUDO_RATE_WINDOW_MS=60000
# EMBER_SUDO_RATE_LIMIT=3

# Parallel task controls (global caps and policy defaults)
# EMBER_MAX_PARALLEL_TASKS=8
# EMBER_MAX_PARALLEL_DEPTH=1
# EMBER_MAX_PARALLEL_CONCURRENCY=4
# EMBER_PARALLEL_TASK_TIMEOUT=180000
# EMBER_PARALLEL_TASK_TIMEOUT_DEFAULT=60000
# EMBER_PARALLEL_TASK_TIMEOUT_MIN=5000
# EMBER_PARALLEL_TRACE_COUNT=120

# MCP and checkpoints
# EMBER_MCP_TIMEOUT=30000
# EMBER_CHECKPOINT_RETENTION=50

# Memory + compaction controls
# EMBER_MEMORY_IDLE_CONSOLIDATION_MS=14400000
# EMBER_CONTEXT_WINDOW=100000
# EMBER_LOCAL_CONTEXT_WINDOW=16000
# EMBER_REMOTE_CONTEXT_CEILING=300000
# EMBER_TOOL_LOOP_LIMIT=200
# EMBER_MAX_TOOL_LOOP_LIMIT=4000
# EMBER_COMPACTION_STAGE1=0.40
# EMBER_COMPACTION_STAGE2=0.60
# EMBER_COMPACTION_STAGE3=0.75
# EMBER_PRESERVE_RECENT=8
# EMBER_MIN_RECENT=4
