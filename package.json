{
  "name": "emberv1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @ember/server dev",
    "dev:web": "pnpm --filter @ember/web dev",
    "doctor": "bash scripts/doctor.sh",
    "lint": "pnpm -r --if-present lint",
    "start": "pnpm --filter @ember/cli dev start",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r typecheck",
    "security:audit": "pnpm audit --prod --audit-level=high"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
