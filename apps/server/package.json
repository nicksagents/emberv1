{
  "name": "@ember/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "bash -lc 'shopt -s globstar nullglob; tests=(src/**/*.test.ts); if [ ${#tests[@]} -eq 0 ]; then echo \"No test files found.\"; exit 0; fi; node --import tsx --test --test-concurrency=1 --test-force-exit \"${tests[@]}\"'"
  },
  "dependencies": {
    "@ember/connectors": "workspace:*",
    "@ember/core": "workspace:*",
    "@ember/desktop-mcp": "workspace:*",
    "@ember/project-scaffold-mcp": "workspace:*",
    "@ember/prompts": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@modelcontextprotocol/server-brave-search": "^0.6.2",
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "@modelcontextprotocol/server-gitlab": "^2025.4.25",
    "@modelcontextprotocol/server-google-maps": "^0.6.2",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@modelcontextprotocol/server-postgres": "^0.6.2",
    "@modelcontextprotocol/server-puppeteer": "^2025.5.12",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.12.18",
    "@modelcontextprotocol/server-slack": "^2025.4.25",
    "@napi-rs/canvas": "^0.1.89",
    "@playwright/mcp": "^0.0.68",
    "fastify": "^5.2.1",
    "gmail-mcp-imap": "^1.0.2",
    "mcp-outlook-mail": "^1.1.0",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^5.5.207",
    "playwright": "^1.58.2"
  }
}
