#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT_DIR"

# ── Colours ────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

log()  { echo -e "${BLUE}▶${NC} $*"; }
ok()   { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
err()  { echo -e "${RED}✗${NC} $*" >&2; }
die()  { err "$*"; exit 1; }

# ── Sanity check ──────────────────────────────────────────────────────────
if [ ! -f "$ROOT_DIR/pnpm-workspace.yaml" ]; then
  die "Run this script from the Ember repo root, or install globally via scripts/install.sh"
fi

# ── Load .env ─────────────────────────────────────────────────────────────
if [ -f "$ROOT_DIR/.env" ]; then
  # Export only lines that look like KEY=VALUE (skip comments and blanks)
  set -o allexport
  # shellcheck disable=SC1091
  source <(grep -E '^[A-Z_]+=.*' "$ROOT_DIR/.env" || true)
  set +o allexport
fi

WEB_PORT="${EMBER_WEB_PORT:-3000}"
SERVER_PORT="${EMBER_RUNTIME_PORT:-3005}"

# ── Pre-flight: packages built? ────────────────────────────────────────────
if [ ! -f "$ROOT_DIR/packages/core/dist/index.js" ]; then
  warn "Packages not built yet — run scripts/install.sh first."
  warn "Attempting quick build now..."
  pnpm --filter @ember/core build --silent
  pnpm --filter @ember/ui-schema build --silent
  pnpm --filter @ember/connectors build --silent
  pnpm --filter @ember/prompts build --silent
fi

# ── Banner ─────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}  🔥 Ember${NC}"
echo -e "  API server  →  http://localhost:${SERVER_PORT}"
echo -e "  Web UI      →  http://localhost:${WEB_PORT}"
echo ""
echo -e "  ${YELLOW}Ctrl-C to stop both services${NC}"
echo ""

# ── Start services ─────────────────────────────────────────────────────────
pnpm --filter @ember/server dev &
SERVER_PID=$!

pnpm --filter @ember/web dev &
WEB_PID=$!

# Open browser after services have had time to start (macOS / Linux)
(sleep 5 && {
  if command -v open &>/dev/null; then
    open "http://localhost:${WEB_PORT}"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "http://localhost:${WEB_PORT}"
  fi
}) &
OPEN_PID=$!

# ── Graceful shutdown ──────────────────────────────────────────────────────
cleanup() {
  echo ""
  log "Shutting down Ember..."
  kill "$SERVER_PID" "$WEB_PID" "$OPEN_PID" 2>/dev/null || true
  wait "$SERVER_PID" "$WEB_PID" 2>/dev/null || true
  ok "Stopped."
}
trap cleanup INT TERM EXIT

wait "$SERVER_PID" "$WEB_PID"
