#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
export EMBER_ROOT="$ROOT_DIR"

case " ${NODE_OPTIONS-} " in
  *" --disable-warning=ExperimentalWarning "*) ;;
  *) export NODE_OPTIONS="${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=ExperimentalWarning" ;;
esac

CLI_DIST="$ROOT_DIR/packages/cli/dist/index.js"
CLI_SRC="$ROOT_DIR/packages/cli/src/index.ts"
TSX_BIN="$ROOT_DIR/node_modules/.bin/tsx"

if [ -f "$CLI_DIST" ]; then
  exec node "$CLI_DIST" "$@"
fi

if [ -x "$TSX_BIN" ]; then
  exec "$TSX_BIN" "$CLI_SRC" "$@"
fi

echo "EMBER CLI is not ready yet. Run ./scripts/install.sh first." >&2
exit 1
